{
  "manifest_version": 3,
  "key": "",
  "name": "Bookmark Swap",
  "version": "1.0.0",
  "description": "Switch between different bookmark bar profiles (Work, Personal, etc.)",
  "permissions": [
    "bookmarks",
    "storage",
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
